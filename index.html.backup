    function doSmartSearch() {
      const start = document.getElementById('homeSearchStart')?.value;
      const end = document.getElementById('homeSearchEnd')?.value;
      const guests = Number(document.getElementById('homeSearchGuests')?.value || 2);
      const budget = Number(document.getElementById('homeSearchBudget')?.value || 100000);
      const district = document.getElementById('homeSearchDistrict')?.value || '';

      if (!start || !end || end <= start) {
        toast('Выберите корректные даты');
        return;
      }

      const available = getAvailableApartments(start, end, guests, budget, district);
      const best = getBestRecommendation(start, end, guests, budget, district);

      if (!available.length) {
        toast('К сожалению, нет доступных квартир по вашим критериям');
        return;
      }

      // Сохраню параметры поиска и перейду в каталог с фильтрами
      sessionStorage.setItem('smartSearchParams', JSON.stringify({ start, end, guests, budget, district }));
      pushRoute('#/catalog');
      renderCatalog();
      // Применю фильтры в каталоге
      setTimeout(() => {
        document.getElementById('searchInput').value = district;
        renderCatalogList();
        if (best) {
          toast(`Рекомендуем: ${best.title} за ${fmtMoney(best.basePrice)}/ночь`);
        }
      }, 100);
    }

    function renderCatalog() {
      document.getElementById('catalog').innerHTML = `
        <div class="panel">
          <h2>${t('catalogTitle')}</h2>
          <div class="filters" style="margin-top:8px;">
            <div class="field"><label>${t('search')}</label><input id="searchInput" placeholder="Название или район"></div>
            <div class="field"><label>${t('price')}</label><select id="priceFilter"><option value="all">${t('any')}</option><option value="15000">до 15 000</option><option value="22000">15 001 - 22 000</option><option value="25000">22 001 - 25 000</option><option value="999999">от 25 001</option></select></div>
            <div class="field"><label>${t('rooms')}</label><select id="roomFilter"><option value="all">${t('anyRooms')}</option><option value="1">1</option><option value="2">2</option><option value="3">3+</option></select></div>
            <div class="field"><label>${t('sorting')}</label><select id="sortFilter"><option value="popular">${t('popularSort')}</option><option value="rating">${t('ratingSort')}</option><option value="priceAsc">${t('price')} ↑</option><option value="priceDesc">${t('price')} ↓</option></select></div>
            <div class="field"><label>${t('action')}</label><button class="btn btn-primary" onclick="renderCatalogList()">${t('apply')}</button></div>
          </div>
        </div>
        <div id="catalogList" class="grid" style="margin-top:12px;"></div>
      `;

      ['searchInput','priceFilter','roomFilter','sortFilter'].forEach((id) => {
        const node = document.getElementById(id);
        node.addEventListener('input', renderCatalogList);
        node.addEventListener('change', renderCatalogList);
      });

      renderCatalogList();
    }

    function renderCatalogList() {
      const s = (document.getElementById('searchInput')?.value || '').toLowerCase();
      const pf = document.getElementById('priceFilter')?.value || 'all';
      const rf = document.getElementById('roomFilter')?.value || 'all';
      const sf = document.getElementById('sortFilter')?.value || 'popular';

      let list = APARTMENTS.filter((a) => {
        const hay = (a.title + ' ' + a.district).toLowerCase();
        const searchOk = !s || hay.includes(s);
        let priceOk = true;
        if (pf === '15000') priceOk = a.basePrice <= 15000;
        if (pf === '22000') priceOk = a.basePrice > 15000 && a.basePrice <= 22000;
        if (pf === '25000') priceOk = a.basePrice > 22000 && a.basePrice <= 25000;
        if (pf === '999999') priceOk = a.basePrice > 25000;
        let roomOk = true;
        if (rf === '1') roomOk = a.rooms === 1;
        if (rf === '2') roomOk = a.rooms === 2;
        if (rf === '3') roomOk = a.rooms >= 3;
        return searchOk && priceOk && roomOk;
      });

      if (sf === 'popular') list.sort((a,b) => b.popularity - a.popularity);
      if (sf === 'rating') list.sort((a,b) => b.rating - a.rating);
      if (sf === 'priceAsc') list.sort((a,b) => a.basePrice - b.basePrice);
      if (sf === 'priceDesc') list.sort((a,b) => b.basePrice - a.basePrice);

      document.getElementById('catalogList').innerHTML = list.map((a) => `
        <article class="apartment" style="cursor:pointer;" onclick="viewApartmentBySlug('${a.slug}')">
          <div class="ap-media">
            ${carouselHtml(a, 'catalog')}
          </div>
          <div class="ap-copy">
            <div style="display:flex; gap:6px; flex-wrap:wrap;">
              <span class="pill">${a.district}</span>
              <span class="pill">⭐ ${a.rating}</span>
              <span class="pill">${t('fromNights', { n: a.minStay })}</span>
            </div>
            <h3>${a.title}</h3>
            <p class="muted">Площадь ${a.area} м², ${a.rooms} комнаты, до ${a.guests} гостей</p>
            <div class="price-line">
              <div>
                <strong>${fmtMoney(a.basePrice)}</strong>
                <div class="muted">${t('basePriceNight')}</div>
              </div>
              <div style="display:flex; gap:8px; flex-wrap:wrap;">
                <button class="btn btn-ghost" onclick="event.stopPropagation(); toggleFavorite('${a.id}')">${isFavorite(a.id) ? t('inFavorites') : t('addFavorite')}</button>
                <button class="btn btn-ghost" onclick="event.stopPropagation(); viewApartmentBySlug('${a.slug}')">${t('page')}</button>
                <button class="btn btn-primary" onclick="event.stopPropagation(); openBooking('${a.id}')">${t('book')}</button>
              </div>
            </div>
          </div>
        </article>
      `).join('');

      initCarousels();
    }

