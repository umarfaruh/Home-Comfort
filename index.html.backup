<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Home Comfort - Суточная аренда квартир в Астане</title>
  <meta name="description" content="Суточная аренда 6 проверенных квартир: онлайн бронирование, календарь занятости, оплата, отзывы, карта и поддержка 24/7.">
  <meta name="keywords" content="суточная аренда, квартиры посуточно, Астана, booking apartment, short term rental">
  <meta name="author" content="Home Comfort">
  <meta name="robots" content="index,follow,max-image-preview:large">
  <link rel="canonical" href="https://homecomfort.example/">

  <meta property="og:type" content="website">
  <meta property="og:title" content="Home Comfort - Суточная аренда квартир">
  <meta property="og:description" content="Профессиональный сервис посуточной аренды: фото, цены, календарь занятости, онлайн-бронирование.">
  <meta property="og:url" content="https://homecomfort.example/">
  <meta property="og:image" content="https://images.unsplash.com/photo-1493666438817-866a91353ca9?auto=format&fit=crop&w=1200&q=80&fm=webp">
  <meta property="og:site_name" content="Home Comfort">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Home Comfort - Суточная аренда квартир">
  <meta name="twitter:description" content="Бронирование квартир по дням с прозрачными ценами и красивым интерфейсом.">
  <meta name="twitter:image" content="https://images.unsplash.com/photo-1493666438817-866a91353ca9?auto=format&fit=crop&w=1200&q=80&fm=webp">

  <link rel="manifest" href="./manifest.webmanifest">
  <meta name="theme-color" content="#0f766e">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <link rel="icon" href="./icons/home-comfort-icon.svg" type="image/svg+xml">

  <link rel="preconnect" href="https://images.unsplash.com">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="">
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

  <style>
    :root {
      --bg: #f6f2e9;
      --surface: rgba(255, 255, 255, 0.9);
      --text: #132033;
      --muted: #5f6d7f;
      --line: rgba(19, 32, 51, 0.12);
      --brand: #0f766e;
      --brand-2: #14b8a6;
      --accent: #d97706;
      --danger: #dc2626;
      --ok: #15803d;
      --radius: 18px;
      --shadow: 0 12px 36px rgba(19, 32, 51, 0.12);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: "Segoe UI", Tahoma, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top left, rgba(20, 184, 166, 0.2), transparent 30%),
        radial-gradient(circle at top right, rgba(217, 119, 6, 0.2), transparent 25%),
        var(--bg);
      min-height: 100vh;
    }
    a { color: inherit; text-decoration: none; }
    button, input, select, textarea { font: inherit; }

    .container {
      width: min(1300px, calc(100% - 24px));
      margin: 12px auto 28px;
    }

    .topbar {
      position: sticky;
      top: 10px;
      z-index: 30;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      padding: 12px 16px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,0.6);
      backdrop-filter: blur(14px);
      background: var(--surface);
      box-shadow: var(--shadow);
    }

    .logo { font-weight: 800; display: flex; align-items: center; gap: 10px; }
    .logo-mark {
      width: 42px; height: 42px; border-radius: 12px;
      display: grid; place-items: center;
      color: #fff; font-weight: 700;
      background: linear-gradient(135deg, var(--brand), var(--brand-2), var(--accent));
    }

    .nav { display: flex; flex-wrap: wrap; gap: 8px; }
    .nav button, .btn {
      border: 0;
      border-radius: 12px;
      padding: 10px 14px;
      cursor: pointer;
      transition: .2s;
    }
    .nav button { background: transparent; color: var(--muted); font-weight: 600; }
    .nav button.active, .nav button:hover { background: rgba(15,118,110,0.12); color: var(--brand); }

    .btn-primary { background: linear-gradient(135deg, var(--brand), var(--brand-2)); color: #fff; font-weight: 700; }
    .btn-ghost { background: #fff; border: 1px solid var(--line); }
    .btn-danger { background: rgba(220,38,38,0.12); color: var(--danger); }
    .btn-warning { background: rgba(217,119,6,0.14); color: #b45309; }

    .hero {
      margin-top: 14px;
      border-radius: 28px;
      overflow: hidden;
      padding: 24px;
      color: #fff;
      background: linear-gradient(135deg, #0f766e, #155e75 60%, #d97706);
      box-shadow: var(--shadow);
    }

    .hero h1 { font-size: clamp(2rem, 4vw, 4rem); line-height: 1; margin-bottom: 12px; }
    .hero p { max-width: 760px; opacity: .95; margin-bottom: 14px; }

    .grid { display: grid; gap: 14px; }
    .cards-3 { grid-template-columns: repeat(3, minmax(0,1fr)); }
    .cards-2 { grid-template-columns: repeat(2, minmax(0,1fr)); }

    .panel {
      background: var(--surface);
      border-radius: var(--radius);
      border: 1px solid rgba(255,255,255,0.6);
      box-shadow: var(--shadow);
      padding: 16px;
    }

    .section { display: none; margin-top: 16px; }
    .section.active { display: block; }
    .section h2 { margin: 0 0 10px; }
    .muted { color: var(--muted); }

    .filters { display: grid; grid-template-columns: 1.7fr repeat(4, 1fr); gap: 10px; }
    .field { display: grid; gap: 6px; }
    .field input, .field select, .field textarea {
      width: 100%; padding: 10px 12px; border: 1px solid var(--line); border-radius: 10px; background: #fff;
    }

    .apartment {
      display: grid;
      grid-template-columns: 1.1fr .9fr;
      gap: 14px;
      min-height: 360px;
      border-radius: var(--radius);
      overflow: hidden;
      background: #fff;
      border: 1px solid var(--line);
    }

    .ap-media { padding: 12px; background: #f8fafc; display: grid; }
    .ap-gallery { margin-top: 12px; }

    .ap-media-row {
      display: grid;
      grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
      gap: 12px;
      max-width: 980px;
      margin: 0 auto;
      align-items: stretch;
    }
    .ap-video-box {
      border-radius: 14px;
      overflow: hidden;
      border: 1px solid var(--line);
      background: #0b1220;
      min-height: 220px;
    }
    .ap-video-box video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .ap-photo-box .carousel-lg .carousel-slide { min-height: 220px; }

    .ap-media-row.ap-media-row-square {
      grid-template-columns: repeat(2, minmax(0, 260px));
      justify-content: center;
      max-width: none;
    }
    .ap-media-row.ap-media-row-square .ap-video-box,
    .ap-media-row.ap-media-row-square .ap-photo-box .carousel {
      min-height: 0;
      aspect-ratio: 1 / 1;
      height: auto;
    }
    .ap-media-row.ap-media-row-square .carousel-track,
    .ap-media-row.ap-media-row-square .carousel-slide,
    .ap-media-row.ap-media-row-square .carousel-slide img,
    .ap-media-row.ap-media-row-square .ap-video-box video {
      height: 100%;
    }
    .ap-media-row.ap-media-row-square .carousel-slide,
    .ap-media-row.ap-media-row-square .ap-photo-box .carousel-lg .carousel-slide {
      min-height: 0;
    }

    .carousel {
      position: relative;
      border-radius: 14px;
      overflow: hidden;
      border: 1px solid var(--line);
      background: #0b1220;
      height: 100%;
    }
    .carousel-track {
      display: flex;
      height: 100%;
      transition: transform .35s ease;
      will-change: transform;
    }
    .carousel-slide {
      min-width: 100%;
      min-height: 260px;
      cursor: pointer;
    }
    .carousel-slide img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .carousel-md .carousel-slide { min-height: 300px; }
    .carousel-lg .carousel-slide { min-height: 420px; }

    .carousel-btn {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      z-index: 2;
      width: 36px;
      height: 36px;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.4);
      background: rgba(11, 18, 32, 0.55);
      color: #fff;
      font-weight: 700;
      cursor: pointer;
    }
    .carousel-btn.prev { left: 10px; }
    .carousel-btn.next { right: 10px; }

    .carousel-dots {
      position: absolute;
      left: 50%;
      bottom: 10px;
      transform: translateX(-50%);
      z-index: 2;
      display: flex;
      gap: 6px;
      padding: 6px 8px;
      border-radius: 999px;
      background: rgba(11, 18, 32, 0.45);
    }
    .carousel-dot {
      width: 8px;
      height: 8px;
      border-radius: 999px;
      border: 0;
      cursor: pointer;
      background: rgba(255, 255, 255, 0.5);
    }
    .carousel-dot.active { background: #fff; }

    .carousel-progress {
      position: absolute;
      left: 10px;
      right: 10px;
      bottom: 44px;
      z-index: 2;
      height: 4px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.28);
      overflow: hidden;
    }
    .carousel-progress-fill {
      width: 100%;
      height: 100%;
      transform-origin: left center;
      transform: scaleX(0);
      background: linear-gradient(90deg, #14b8a6, #f59e0b);
      transition: transform 120ms linear;
    }

    .shot {
      position: relative;
      border-radius: 12px;
      overflow: hidden;
      min-height: 120px;
      cursor: pointer;
      border: 1px solid var(--line);
    }
    .shot img { width: 100%; height: 100%; object-fit: cover; }

    .pill { display: inline-flex; gap: 6px; padding: 5px 10px; border-radius: 999px; background: rgba(19,32,51,0.08); font-size: .85rem; }

    .ap-copy { padding: 14px; display: grid; gap: 10px; }

    .price-line {
      display: flex; align-items: center; justify-content: space-between;
      background: rgba(15,118,110,0.1);
      border-radius: 12px; padding: 10px 12px;
    }

    .calendar {
      display: grid;
      grid-template-columns: repeat(7, minmax(0,1fr));
      gap: 6px;
      margin-top: 10px;
    }
    .cal-head { text-align: center; font-size: .8rem; color: var(--muted); font-weight: 700; }
    .day {
      min-height: 44px;
      border-radius: 10px;
      border: 1px solid var(--line);
      background: #fff;
      cursor: pointer;
      font-size: .85rem;
      display: grid;
      place-items: center;
    }
    .day.booked { background: rgba(220,38,38,0.15); color: var(--danger); cursor: not-allowed; }
    .day.blocked { background: rgba(217,119,6,0.2); color: #b45309; cursor: not-allowed; }
    .day.selected { background: rgba(15,118,110,0.18); color: var(--brand); }
    .day.past { opacity: .5; cursor: not-allowed; }

    .map-wrap { min-height: 380px; border-radius: 14px; overflow: hidden; border: 1px solid var(--line); }

    .table { width: 100%; border-collapse: collapse; font-size: .92rem; }
    .table th, .table td { border-bottom: 1px solid var(--line); padding: 8px; text-align: left; }

    .modal {
      position: fixed; inset: 0;
      background: rgba(10,18,30,0.5);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 80;
      padding: 14px;
    }
    .modal.open { display: flex; }
    .modal-body {
      width: min(1100px, 100%);
      max-height: 90vh;
      overflow: auto;
      background: #fff;
      border-radius: 16px;
      padding: 16px;
    }

    .lightbox-img {
      width: 100%;
      max-height: 70vh;
      object-fit: contain;
      border-radius: 12px;
      background: #0b1220;
    }

    .chat-toggle {
      position: fixed;
      right: 18px;
      bottom: 18px;
      z-index: 60;
      border: 0;
      border-radius: 999px;
      background: linear-gradient(135deg, var(--brand), var(--brand-2));
      color: #fff;
      padding: 12px 16px;
      box-shadow: var(--shadow);
      cursor: pointer;
      font-weight: 700;
    }

    .chat {
      position: fixed;
      right: 18px;
      bottom: 70px;
      width: min(360px, calc(100% - 24px));
      height: 460px;
      z-index: 61;
      display: none;
      grid-template-rows: auto 1fr auto;
      background: #fff;
      border-radius: 16px;
      border: 1px solid var(--line);
      box-shadow: var(--shadow);
      overflow: hidden;
    }
    .chat.open { display: grid; }
    .chat-head { padding: 10px 12px; background: #f8fafc; border-bottom: 1px solid var(--line); display: flex; justify-content: space-between; }
    .chat-log { padding: 10px; overflow: auto; display: grid; gap: 8px; background: #fcfcfd; }
    .msg { padding: 8px 10px; border-radius: 10px; max-width: 85%; font-size: .9rem; }
    .msg.bot { background: #eef2f7; }
    .msg.me { margin-left: auto; background: rgba(15,118,110,0.14); }
    .chat-form { display: grid; grid-template-columns: 1fr auto; gap: 8px; padding: 8px; border-top: 1px solid var(--line); }

    .toast-wrap { position: fixed; right: 10px; top: 10px; z-index: 100; display: grid; gap: 8px; }
    .toast { background: #132033; color: #fff; padding: 10px 12px; border-radius: 10px; }

    @media (max-width: 1000px) {
      .cards-3, .cards-2, .filters, .apartment { grid-template-columns: 1fr; }
      .topbar { border-radius: 16px; }
      .ap-media-row { grid-template-columns: 1fr; max-width: none; }
      .ap-media-row.ap-media-row-square { grid-template-columns: 1fr; }
      .ap-video-box,
      .ap-photo-box .carousel-lg .carousel-slide { min-height: 190px; }
      .carousel-md .carousel-slide,
      .carousel-lg .carousel-slide { min-height: 260px; }
    }
  </style>

  <script type="application/ld+json">
  {
    "@context":"https://schema.org",
    "@type":"LodgingBusiness",
    "name":"Home Comfort",
    "description":"Сервис посуточной аренды квартир с онлайн-бронированием",
    "telephone":"+77001929260",
    "areaServed":"Astana",
    "url":"https://homecomfort.example/"
  }
  </script>
</head>
<body>
  <div class="container">
    <header class="topbar">
      <div class="logo">
        <div class="logo-mark">HC</div>
        <div>
          <div>Home Comfort</div>
          <small class="muted" id="brandTagline">Суточная аренда квартир</small>
        </div>
      </div>
      <nav class="nav" id="nav"></nav>
      <div style="display:flex; gap:8px; align-items:center;">
        <select id="langSwitcher" class="btn btn-ghost" aria-label="Language">
          <option value="ru">RU</option>
          <option value="kz">KZ</option>
          <option value="en">EN</option>
        </select>
        <button class="btn btn-ghost" id="chatOpenBtn">Онлайн-чат</button>
        <button class="btn btn-primary" id="authBtn">Профиль</button>
      </div>
    </header>

    <section id="home" class="section active"></section>
    <section id="catalog" class="section"></section>
    <section id="apartmentPage" class="section"></section>
    <section id="dashboard" class="section"></section>
    <section id="profile" class="section"></section>
    <section id="owner" class="section"></section>
    <section id="about" class="section"></section>
  </div>

  <button class="chat-toggle" id="chatFab">Чат</button>
  <aside class="chat" id="chatWidget">
    <div class="chat-head">
      <strong id="chatTitle">Онлайн-чат</strong>
      <button class="btn btn-ghost" id="chatCloseBtn">Закрыть</button>
    </div>
    <div class="chat-log" id="chatLog"></div>
    <form class="chat-form" id="chatForm">
      <input id="chatInput" placeholder="Напишите вопрос...">
      <button class="btn btn-primary" id="chatSendBtn" type="submit">Отправить</button>
    </form>
  </aside>

  <div class="modal" id="lightboxModal">
    <div class="modal-body">
      <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
        <strong id="lightboxTitle">Фото</strong>
        <button class="btn btn-ghost" id="lightboxClose">Закрыть</button>
      </div>
      <img id="lightboxImage" class="lightbox-img" alt="Apartment photo">
      <div style="display:flex; justify-content:space-between; margin-top:10px;">
        <button class="btn btn-ghost" id="lightboxPrev">Назад</button>
        <button class="btn btn-ghost" id="lightboxNext">Вперёд</button>
      </div>
    </div>
  </div>

  <div class="modal" id="authModal">
    <div class="modal-body" style="width:min(520px,100%);">
      <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
        <strong id="authModalTitle">Вход и регистрация</strong>
        <button class="btn btn-ghost" id="authClose">Закрыть</button>
      </div>
      <div class="grid cards-2" style="margin-bottom:12px;">
        <button class="btn btn-ghost" id="tabLogin">Вход</button>
        <button class="btn btn-ghost" id="tabRegister">Регистрация</button>
      </div>
      <div id="authContent"></div>
    </div>
  </div>

  <div class="toast-wrap" id="toasts"></div>

  <script>
    const STORAGE = 'staydaily-v3';
    const LANG_STORAGE = 'staydaily-lang';
    const SUPPORTED_LANGS = ['ru', 'kz', 'en'];

    const I18N = {
      ru: {
        navHome: 'Главная', navCatalog: 'Квартиры', navDashboard: 'Кабинет', navOwner: 'Панель управления', navAbout: 'О нас',
        brandTagline: 'Суточная аренда квартир', chat: 'Чат', onlineChat: 'Онлайн-чат', close: 'Закрыть', send: 'Отправить', profile: 'Профиль',
        questionPlaceholder: 'Напишите вопрос...', prev: 'Назад', next: 'Вперёд',
        heroTitle: 'Суточные квартиры, которые выглядят как отельный уровень',
        heroText: 'Реальные фото, прозрачный календарь, динамические цены по сезонам, верификация гостей и моментальный контакт в чате + WhatsApp.',
        viewApartments: 'Смотреть квартиры',
        topApartments: 'Топ квартиры',
        catalogTitle: 'Каталог квартир', search: 'Поиск', price: 'Цена', rooms: 'Комнат', sorting: 'Сортировка', action: 'Действие', apply: 'Применить',
        any: 'Любая', anyRooms: 'Любые', popularSort: 'По популярности', ratingSort: 'По рейтингу',
        fromNights: 'От {n} ночи', basePriceNight: 'базовая цена / ночь (динамика по датам)',
        inFavorites: 'В избранном', addFavorite: 'В избранное', page: 'Страница', book: 'Бронировать',
        rating: 'рейтинг', mapTitle: 'Локация на карте', mapText: 'Удобно для гостя: карта открывается прямо на странице квартиры.',
        whatsapp: 'WhatsApp', backToCatalog: 'Назад в каталог', bookingTerm: 'Срок брони', views: 'Просмотров',
        loginTitle: 'Вход и регистрация', loginTab: 'Вход', registerTab: 'Регистрация',
        loginBtn: 'Войти', createAccount: 'Создать аккаунт', name: 'Имя', phone: 'Телефон', password: 'Пароль'
      },
      kz: {
        navHome: 'Басты бет', navCatalog: 'Пәтерлер', navDashboard: 'Кабинет', navOwner: 'Басқару панелі', navAbout: 'Біз туралы',
        brandTagline: 'Тәуліктік пәтер жалдау', chat: 'Чат', onlineChat: 'Онлайн чат', close: 'Жабу', send: 'Жіберу', profile: 'Профиль',
        questionPlaceholder: 'Сұрағыңызды жазыңыз...', prev: 'Артқа', next: 'Келесі',
        heroTitle: 'Қонақүй деңгейіндегі тәуліктік пәтерлер',
        heroText: 'Нақты фото, ашық күнтізбе, маусымға сай динамикалық баға, қонақ верификациясы және чат + WhatsApp арқылы жедел байланыс.',
        viewApartments: 'Пәтерлерді көру',
        topApartments: 'Үздік пәтерлер',
        catalogTitle: 'Пәтерлер каталогы', search: 'Іздеу', price: 'Баға', rooms: 'Бөлме', sorting: 'Сұрыптау', action: 'Әрекет', apply: 'Қолдану',
        any: 'Кез келген', anyRooms: 'Кез келген', popularSort: 'Танымалдылық бойынша', ratingSort: 'Рейтинг бойынша',
        fromNights: '{n} түннен', basePriceNight: 'негізгі баға / түн (күнге қарай өзгереді)',
        inFavorites: 'Таңдаулыда', addFavorite: 'Таңдаулыға', page: 'Бет', book: 'Брондау',
