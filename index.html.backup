    function addViewHistory(apartmentId) {
      state.viewHistory = state.viewHistory.filter((v) => v.id !== apartmentId);
      state.viewHistory.unshift({ id: apartmentId, at: new Date().toISOString() });
      if (state.viewHistory.length > 20) state.viewHistory = state.viewHistory.slice(0, 20);
      saveState();
    }

    function getRecentlyViewed() {
      return state.viewHistory.map((v) => APARTMENTS.find((a) => a.id === v.id)).filter(Boolean).slice(0, 6);
    }

    function getAvailableApartments(startDate, endDate, minGuests, maxPrice, districtFilter) {
      const dates = rangeDates(startDate, endDate).map((d) => ymd(d));
      return APARTMENTS.filter((a) => {
        const guestMatch = a.guests >= minGuests;
        const priceMatch = a.basePrice <= maxPrice;
        const districtMatch = !districtFilter || a.district.toLowerCase().includes(districtFilter.toLowerCase());
        const dateMatch = !dates.some((d) => a.blacklist.includes(d) || isDateBusy(a.id, d));
        const stayMatch = dates.length >= a.minStay;
        return guestMatch && priceMatch && districtMatch && dateMatch && stayMatch;
      });
    }

    function getBestRecommendation(startDate, endDate, minGuests, maxPrice, districtFilter) {
      const available = getAvailableApartments(startDate, endDate, minGuests, maxPrice, districtFilter);
      if (!available.length) return null;
      return available.sort((a, b) => b.rating - a.rating || b.popularity - a.popularity)[0];
    }

    const state = loadState();
    let apartmentMapInstance = null;
    let lightbox = { apartmentId: null, index: 0 };
    const carouselState = {};
    const carouselAutoPlayTimers = {};
    const carouselProgressState = {};
    const CAROUSEL_AUTO_MS = 5000;
    const CAROUSEL_PROGRESS_STEP_MS = 100;

    function defaultState() {
      return {
        users: [
          { id: 'admin', role: 'admin', name: 'Admin', email: 'admin@staydaily.pro', password: 'demo123', phone: '+7 700 192 9260', referralCode: 'ADMIN01' },
          { id: 'owner', role: 'owner', name: 'Owner', email: 'owner@staydaily.pro', password: 'demo123', phone: '+7 700 192 9260', referralCode: 'OWNER01' },
          { id: 'guest', role: 'guest', name: 'Guest', email: 'guest@staydaily.pro', password: 'demo123', phone: '+7 700 555 0101', referralCode: 'GUEST01' }
        ],
        sessionUserId: null,
        bookings: [],
        favorites: {},
        occupancy: {},
        viewHistory: [],
        chat: [{ from: 'bot', text: 'Здравствуйте! Я онлайн-помощник Home Comfort. Помогу выбрать квартиру или оформить бронь.' }],
        analytics: { views: {}, leads: 0, visits: [], apartmentViews: [] },
        seo: { indexable: true }
      };
    }

    function loadState() {
      try {
        const saved = JSON.parse(localStorage.getItem(STORAGE) || 'null');
        const base = defaultState();
        if (!saved || typeof saved !== 'object') return base;
        return {
          ...base,
          ...saved,
          users: Array.isArray(saved.users) && saved.users.length ? saved.users : base.users,
          bookings: Array.isArray(saved.bookings) ? saved.bookings : base.bookings,
          favorites: saved.favorites && typeof saved.favorites === 'object' ? saved.favorites : base.favorites,
          viewHistory: Array.isArray(saved.viewHistory) ? saved.viewHistory : base.viewHistory,
          chat: Array.isArray(saved.chat) && saved.chat.length ? saved.chat : base.chat,
          analytics: saved.analytics && typeof saved.analytics === 'object'
            ? {
              ...base.analytics,
              ...saved.analytics,
              visits: Array.isArray(saved.analytics.visits) ? saved.analytics.visits : base.analytics.visits,
              apartmentViews: Array.isArray(saved.analytics.apartmentViews) ? saved.analytics.apartmentViews : base.analytics.apartmentViews
            }
            : base.analytics,
          occupancy: saved.occupancy && typeof saved.occupancy === 'object' ? saved.occupancy : base.occupancy
        };
      } catch (e) {
        return defaultState();
      }
    }

    function saveState() {
      localStorage.setItem(STORAGE, JSON.stringify(state));
    }

    function user() {
      return state.users.find((u) => u.id === state.sessionUserId) || null;
    }

    function fmtMoney(v) {
      return new Intl.NumberFormat('ru-RU').format(Math.round(v)) + ' ₸';
    }

    function favoriteIdsForUser() {
      const u = user();
      if (!u) return [];
      const list = state.favorites[u.id];
      return Array.isArray(list) ? list : [];
    }

    function isFavorite(apartmentId) {
      return favoriteIdsForUser().includes(apartmentId);
    }

    function toggleFavorite(apartmentId) {
      const u = user();
      if (!u) {
        openAuth();
        return;
      }
      const prev = favoriteIdsForUser();
      const exists = prev.includes(apartmentId);
      const next = exists ? prev.filter((id) => id !== apartmentId) : [...prev, apartmentId];
      state.favorites[u.id] = next;
      saveState();
      renderCatalogList();
      if ((location.hash || '').startsWith('#/apartment/')) {
        const slug = location.hash.replace('#/apartment/', '');
        renderApartmentPage(slug);
      }
      renderDashboard();
      toast(exists ? 'Убрано из избранного' : 'Добавлено в избранное');
    }

    function toast(msg) {
      const node = document.createElement('div');
      node.className = 'toast';
      node.textContent = msg;
      document.getElementById('toasts').appendChild(node);
      setTimeout(() => node.remove(), 3200);
    }

    function navItems() {
      return [
        { id: 'home', title: t('navHome') },
        { id: 'catalog', title: t('navCatalog') },
        { id: 'dashboard', title: t('navDashboard') },
        { id: 'owner', title: t('navOwner') },
        { id: 'about', title: t('navAbout') }
      ];
    }

    function setActiveSection(id) {
      document.querySelectorAll('.section').forEach((section) => section.classList.remove('active'));
      const node = document.getElementById(id);
      if (node) node.classList.add('active');
      document.querySelectorAll('.nav button').forEach((btn) => btn.classList.toggle('active', btn.dataset.target === id));
    }

    function pushRoute(path) {
      if (location.hash !== path) location.hash = path;
    }

    function resolveRoute() {
      const hash = location.hash || '#/home';
      if (hash.startsWith('#/apartment/')) {
        const slug = hash.replace('#/apartment/', '');
        renderApartmentPage(slug);
        setActiveSection('apartmentPage');
        return;
      }

      const target = hash.replace('#/', '');
      if (['home', 'catalog', 'dashboard', 'profile', 'owner', 'about'].includes(target)) {
        setActiveSection(target);
      } else {
        pushRoute('#/home');
      }
    }

    function getApartmentBySlug(slug) {
      return APARTMENTS.find((a) => a.slug === slug);
    }

    function viewApartment(apartment) {
      pushRoute('#/apartment/' + apartment.slug);
    }

    function getVisitorId() {
      let id = localStorage.getItem('staydaily-visitor-id');
      if (!id) {
        id = 'v-' + Math.random().toString(36).slice(2, 10);
        localStorage.setItem('staydaily-visitor-id', id);
      }
      return id;
    }

    function trackVisit(route) {
      const u = user();
      const visit = {
        at: new Date().toISOString(),
        route,
        visitorId: getVisitorId(),
        userId: u ? u.id : 'anon',
        userName: u ? u.name : 'Аноним'
      };
      state.analytics.visits.unshift(visit);
      if (state.analytics.visits.length > 500) state.analytics.visits.length = 500;
      saveState();
    }

    function trackApartmentVisit(apartment) {
      const u = user();
      const event = {
        at: new Date().toISOString(),
        apartmentId: apartment.id,
        apartmentTitle: apartment.title,
        visitorId: getVisitorId(),
        userId: u ? u.id : 'anon',
        userName: u ? u.name : 'Аноним'
      };
      state.analytics.apartmentViews.unshift(event);
      if (state.analytics.apartmentViews.length > 500) state.analytics.apartmentViews.length = 500;
      addViewHistory(apartment.id);
      saveState();
    }

    function carouselHtml(apartment, view, options = {}) {
      const carouselId = `${view}-${apartment.id}`;
      const photos = apartment.photos || [];
      const includeVideo = Boolean(options.includeVideo && apartment.video);
      const slides = includeVideo
        ? [{ type: 'video', src: apartment.video, alt: apartment.title + ' видео' }, ...photos.map((p) => ({ type: 'photo', ...p }))]
        : photos.map((p) => ({ type: 'photo', ...p }));
      const index = Math.max(0, Math.min(carouselState[carouselId] || 0, Math.max(slides.length - 1, 0)));
      carouselState[carouselId] = index;
      const sizeClass = view === 'apartment' ? 'carousel-lg' : 'carousel-md';
      const autoPlay = options.autoPlay !== false;
      return `
        <div class="carousel ${sizeClass}" data-carousel-id="${carouselId}" data-count="${slides.length}" data-index="${index}" data-autoplay="${autoPlay ? '1' : '0'}">
          <div class="carousel-track" style="transform: translateX(-${index * 100}%);">
            ${slides.map((slide, idx) => `
              <div class="carousel-slide" ${slide.type === 'photo'
                ? `onclick="${view === 'catalog' ? `viewApartmentBySlug('${apartment.slug}')` : `openLightbox('${apartment.id}', ${includeVideo ? idx - 1 : idx})`}"`
                : ''}>
                ${slide.type === 'video'
                  ? `<video controls preload="metadata" style="width:100%; height:100%; object-fit:cover;" src="${slide.src}"></video>`
                  : `<img src="${slide.thumb}" alt="${slide.alt}" loading="lazy" decoding="async" width="1200" height="800">`
                }
              </div>
            `).join('')}
          </div>
          ${slides.length > 1 ? `
            <div class="carousel-progress"><div class="carousel-progress-fill" data-carousel-progress-id="${carouselId}"></div></div>
            <button class="carousel-btn prev" onclick="event.stopPropagation(); shiftCarousel('${carouselId}', -1)">‹</button>
            <button class="carousel-btn next" onclick="event.stopPropagation(); shiftCarousel('${carouselId}', 1)">›</button>
            <div class="carousel-dots">
              ${slides.map((_, idx) => `<button class="carousel-dot ${idx === index ? 'active' : ''}" onclick="event.stopPropagation(); goToCarouselSlide('${carouselId}', ${idx})"></button>`).join('')}
            </div>
          ` : ''}
        </div>
      `;
    }

    function shiftCarousel(carouselId, delta) {
      const root = document.querySelector(`[data-carousel-id="${carouselId}"]`);
      if (!root) return;
      const count = Number(root.dataset.count || 0);
      if (count <= 1) return;
      const current = Number(root.dataset.index || 0);
      const next = (current + delta + count) % count;
      applyCarouselIndex(root, carouselId, next);
      if (carouselAutoPlayTimers[carouselId]) resetCarouselProgress(carouselId);
    }

    function goToCarouselSlide(carouselId, index) {
      const root = document.querySelector(`[data-carousel-id="${carouselId}"]`);
      if (!root) return;
      applyCarouselIndex(root, carouselId, index);
      if (carouselAutoPlayTimers[carouselId]) resetCarouselProgress(carouselId);
    }

    function applyCarouselIndex(root, carouselId, index) {
      const count = Number(root.dataset.count || 0);
      if (!count) return;
      const next = ((index % count) + count) % count;
      root.dataset.index = String(next
      carouselState[carouselId] = next;
      const track = root.querySelector('.carousel-track');
      if (track) track.style.transform = `translateX(-${next * 100}%)`;
      root.querySelectorAll('.carousel-dot').forEach((dot, idx) => {
        dot.classList.toggle('active', idx === next);
      });
    }

    function paintCarouselProgress(carouselId) {
      const fill = document.querySelector(`[data-carousel-progress-id="${carouselId}"]`);
      if (!fill) return;
      const value = Math.max(0, Math.min(1, carouselProgressState[carouselId] || 0));
      fill.style.transform = `scaleX(${value})`;
    }

    function resetCarouselProgress(carouselId) {
      carouselProgressState[carouselId] = 0;
      paintCarouselProgress(carouselId);
    }

    function stopCarouselAutoPlay(carouselId) {
      if (!carouselAutoPlayTimers[carouselId]) return;
      clearInterval(carouselAutoPlayTimers[carouselId]);
      delete carouselAutoPlayTimers[carouselId];
    }

    function startCarouselAutoPlay(carouselId) {
      stopCarouselAutoPlay(carouselId);
      const root = document.querySelector(`[data-carousel-id="${carouselId}"]`);
      if (!root) return;
      if (root.dataset.autoplay === '0') return;
      const count = Number(root.dataset.count || 0);
      if (count <= 1) return;

      resetCarouselProgress(carouselId);

      carouselAutoPlayTimers[carouselId] = setInterval(() => {
        const node = document.querySelector(`[data-carousel-id="${carouselId}"]`);
        if (!node) {
          stopCarouselAutoPlay(carouselId);
          return;
        }
        if (node.matches(':hover')) return;
        const step = CAROUSEL_PROGRESS_STEP_MS / CAROUSEL_AUTO_MS;
        carouselProgressState[carouselId] = Math.min(1, (carouselProgressState[carouselId] || 0) + step);
        paintCarouselProgress(carouselId);
        if (carouselProgressState[carouselId] >= 1) {
          shiftCarousel(carouselId, 1);
          resetCarouselProgress(carouselId);
        }
      }, CAROUSEL_PROGRESS_STEP_MS);
    }

    function initCarousels() {
      // Clear timers for carousels removed from DOM during rerender.
      Object.keys(carouselAutoPlayTimers).forEach((carouselId) => {
        if (!document.querySelector(`[data-carousel-id="${carouselId}"]`)) {
          stopCarouselAutoPlay(carouselId);
        }
      });

      document.querySelectorAll('.carousel').forEach((root) => {
        const carouselId = root.dataset.carouselId;
        if (!carouselId) return;

        if (!root.dataset.inited) {
          root.dataset.inited = '1';

          let touchStartX = 0;
          let touchStartY = 0;

          root.addEventListener('touchstart', (event) => {
            const touch = event.changedTouches[0];
            touchStartX = touch.clientX;
            touchStartY = touch.clientY;
            stopCarouselAutoPlay(carouselId);
          }, { passive: true });

          root.addEventListener('touchend', (event) => {
            const touch = event.changedTouches[0];
            const dx = touch.clientX - touchStartX;
            const dy = touch.clientY - touchStartY;
            if (Math.abs(dx) > 40 && Math.abs(dx) > Math.abs(dy)) {
              shiftCarousel(carouselId, dx > 0 ? -1 : 1);
            }
            startCarouselAutoPlay(carouselId);
          }, { passive: true });

          root.addEventListener('mouseenter', () => stopCarouselAutoPlay(carouselId));
          root.addEventListener('mouseleave', () => startCarouselAutoPlay(carouselId));
        }

        startCarouselAutoPlay(carouselId);
      });
    }

    function dynamicNightPrice(apartment, dateStr) {
      const date = new Date(dateStr + 'T12:00:00');
      const day = date.getDay();
      const month = date.getMonth() + 1;
      let multiplier = 1;
      if (day === 5 || day === 6) multiplier += 0.15;
      if ([6, 7, 8].includes(month)) multiplier += 0.2;
      if ([12, 1, 2].includes(month)) multiplier += 0.15;
      return apartment.basePrice * multiplier;
    }

    function rangeDates(start, end) {
      const out = [];
      let d = new Date(start + 'T12:00:00');
      const e = new Date(end + 'T12:00:00');
      while (d < e) {
        out.push(new Date(d));
        d.setDate(d.getDate() + 1);
      }
      return out;
    }

    function ymd(date) {
      const y = date.getFullYear();
      const m = String(date.getMonth() + 1).padStart(2, '0');
      const d = String(date.getDate()).padStart(2, '0');
      return `${y}-${m}-${d}`;
    }

    function isDateBusy(apartmentId, dateStr) {
      const occ = state.occupancy[apartmentId] || {};
      return occ[dateStr] || false;
    }

    function applyPromo(total, code, nights) {
      if (!code) return { discount: 0, label: '' };
      const normalized = code.toUpperCase().trim();
      const promo = PROMO_CODES[normalized];
      if (!promo) return { discount: 0, label: 'Промокод не найден' };
      if (promo.minNights && nights < promo.minNights) return { discount: 0, label: `Промокод от ${promo.minNights} ночей` };
      const discount = promo.type === 'fixed' ? promo.value : total * (promo.value / 100);
      return { discount, label: `Промокод ${normalized}` };
    }

    function applyReferral(total, referralCode) {
      if (!referralCode) return { discount: 0, label: '' };
      const owner = state.users.find((u) => u.referralCode && u.referralCode.toUpperCase() === referralCode.toUpperCase());
      if (!owner) return { discount: 0, label: 'Реферальный код не найден' };
      return { discount: total * 0.07, label: `Реферал ${owner.referralCode}` };
    }

