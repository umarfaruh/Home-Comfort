    function renderApartmentMap(apartment) {
      const canvas = document.getElementById('apartmentMap');
      if (!canvas || !window.L) return;
      if (apartmentMapInstance) apartmentMapInstance.remove();
      apartmentMapInstance = window.L.map('apartmentMap', { center: apartment.coords, zoom: 14 });
      window.L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; OpenStreetMap contributors'
      }).addTo(apartmentMapInstance);
      const marker = window.L.marker(apartment.coords).addTo(apartmentMapInstance);
      marker.bindPopup(`<strong>${apartment.title}</strong><br>${apartment.district}<br>${fmtMoney(apartment.basePrice)}`).openPopup();
    }

    function apartmentMediaHtml(apartment) {
      if (!apartment.video) {
        return carouselHtml(apartment, 'apartment', { includeVideo: false, autoPlay: true });
      }
      const isAynabulakCompact = apartment.slug === 'aynabulak-2-85-dom';
      return `
        <div class="ap-media-row ${isAynabulakCompact ? 'ap-media-row-square' : ''}">
          <div class="ap-video-box">
            <video controls preload="metadata" src="${apartment.video}"></video>
          </div>
          <div class="ap-photo-box">
            ${carouselHtml(apartment, 'apartment', { includeVideo: false, autoPlay: true })}
          </div>
        </div>
      `;
    }

    function findNextAvailableStart(apartment, nights, startDate) {
      const probe = new Date(startDate + 'T12:00:00');
      for (let i = 0; i < 365; i++) {
        const candidate = new Date(probe);
        candidate.setDate(candidate.getDate() + i);
        const candidateStart = ymd(candidate);
        const candidateEndDate = new Date(candidate);
        candidateEndDate.setDate(candidateEndDate.getDate() + nights);
        const candidateEnd = ymd(candidateEndDate);
        const range = rangeDates(candidateStart, candidateEnd).map((d) => ymd(d));
        const invalid = range.some((d) => apartment.blacklist.includes(d) || isDateBusy(apartment.id, d));
        if (!invalid && range.length >= apartment.minStay) return { start: candidateStart, end: candidateEnd, dates: range };
      }
      return null;
    }

    function rebookOneClick(bookingId) {
      const u = user();
      if (!u || u.role !== 'guest') {
        toast('Опция доступна в кабинете гостя.');
        return;
      }
      const prev = state.bookings.find((b) => b.id === bookingId && b.userId === u.id);
      if (!prev) {
        toast('Исходная бронь не найдена');
        return;
      }
      const apartment = APARTMENTS.find((a) => a.id === prev.apartmentId);
      if (!apartment) {
        toast('Квартира больше недоступна');
        return;
      }

      const from = ymd(new Date());
      const slot = findNextAvailableStart(apartment, Math.max(prev.nights, apartment.minStay), from);
      if (!slot) {
        toast('Не найдено свободного окна для быстрой повторной брони');
        return;
      }

      const nightly = slot.dates.map((d) => dynamicNightPrice(apartment, d));
      const total = nightly.reduce((s, v) => s + v, 0);
      const booking = {
        id: 'BK-' + Date.now(),
        apartmentId: apartment.id,
        userId: u.id,
        name: u.name,
        phone: u.phone,
        email: u.email,
        start: slot.start,
        end: slot.end,
        nights: slot.dates.length,
        dates: slot.dates,
        paymentMethod: prev.paymentMethod || 'card',
        total,
        promo: '',
        referral: '',
        verification: { sms: true, document: 'rebook-quick' },
        createdAt: new Date().toISOString(),
        source: 'one-click-rebook'
      };

      state.bookings.unshift(booking);
      if (!state.occupancy[apartment.id]) state.occupancy[apartment.id] = {};
      slot.dates.forEach((d) => { state.occupancy[apartment.id][d] = booking.name; });
      state.analytics.leads += 1;
      saveState();
      renderDashboard();
      renderOwner();
      toast(`Повторная бронь создана: ${slot.start} - ${slot.end}`);
    }

    function renderDashboard() {
      const u = user();
      if (!u) {
        document.getElementById('dashboard').innerHTML = `<div class="panel"><h2>Нужен вход</h2><button class="btn btn-primary" onclick="openAuth()">Войти</button></div>`;
        return;
      }

      const myBookings = u.role === 'guest' ? state.bookings.filter((b) => b.userId === u.id) : state.bookings;
      const revenue = state.bookings.reduce((sum, b) => sum + b.total, 0);
      const favoriteApartments = favoriteIdsForUser().map((id) => APARTMENTS.find((a) => a.id === id)).filter(Boolean);

      document.getElementById('dashboard').innerHTML = `
        <div class="grid cards-3">
          <div class="panel"><h3>${u.name}</h3><p class="muted">Ваш рефкод: <strong>${u.referralCode || '-'}</strong></p></div>
          <div class="panel"><strong>${myBookings.length}</strong><p class="muted">Бронирований</p></div>
          <div class="panel"><strong>${fmtMoney(revenue)}</strong><p class="muted">Оборот</p></div>
        </div>

        ${u.role === 'guest' ? `
          <div class="panel" style="margin-top:12px;">
            <h2>Мои любимые квартиры</h2>
            <div class="grid cards-3" style="margin-top:10px;">
              ${favoriteApartments.map((a) => `
                <div class="panel">
                  <div class="shot" onclick="viewApartmentBySlug('${a.slug}')"><img src="${a.photos[0].thumb}" alt="${a.photos[0].alt}" loading="lazy"></div>
                  <h3 style="margin-top:8px;">${a.title}</h3>
                  <p class="muted">${a.district}</p>
                  <div style="display:flex; gap:8px; flex-wrap:wrap; margin-top:8px;">
                    <button class="btn btn-ghost" onclick="toggleFavorite('${a.id}')">Убрать</button>
                    <button class="btn btn-primary" onclick="openBooking('${a.id}')">Бронировать</button>
                  </div>
                </div>
              `).join('') || '<p class="muted">Пока нет избранных квартир. Добавьте их из каталога.</p>'}
            </div>
          </div>
        ` : ''}

        <div class="panel" style="margin-top:12px;">
          <h2>История бронирований и платежей</h2>
          <div style="overflow:auto; margin-top:8px;">
            <table class="table">
              <thead><tr><th>ID</th><th>Квартира</th><th>Даты</th><th>Ночей</th><th>Оплата</th><th>Сумма</th><th>Гость</th></tr></thead>
              <tbody>
                ${myBookings.map((b) => {
                  const a = APARTMENTS.find((x) => x.id === b.apartmentId);
                  const quick = u.role === 'guest' ? `<button class="btn btn-ghost" onclick="rebookOneClick('${b.id}')">Повторить в 1 клик</button>` : '';
                  return `<tr><td>${b.id}</td><td>${a ? a.title : b.apartmentId}</td><td>${b.start} - ${b.end}</td><td>${b.nights}</td><td>${b.paymentMethod}</td><td>${fmtMoney(b.total)}</td><td>${b.name}<div style="margin-top:6px;">${quick}</div></td></tr>`;
                }).join('') || '<tr><td colspan="7">Нет данных</td></tr>'}
              </tbody>
            </table>
          </div>
          ${(u.role === 'owner' || u.role === 'admin') ? `
            <div style="margin-top:10px; display:flex; gap:8px; flex-wrap:wrap;">
              <button class="btn btn-primary" onclick="exportCsv()">Экспорт CSV</button>
              <button class="btn btn-ghost" onclick="exportXls()">Экспорт Excel (.xls)</button>
            </div>
          ` : ''}
        </div>
      `;
    }

    function renderOwner() {
      const u = user();
      if (!u) {
        document.getElementById('owner').innerHTML = `<div class="panel"><h2>Панель управления</h2><p class="muted">Войдите в управляющий аккаунт.</p><button class="btn btn-primary" onclick="openAuth()">Войти</button></div>`;
        return;
      }
      if (!['owner', 'admin'].includes(u.role)) {
        document.getElementById('owner').innerHTML = `<div class="panel"><h2>Доступ ограничен</h2><p class="muted">Эта страница доступна только управляющему аккаунту.</p></div>`;
        return;
      }

      const visits = state.analytics.visits || [];
      const apartmentViews = state.analytics.apartmentViews || [];
      const bookings = state.bookings || [];
      const users = state.users || [];
      const uniqueVisitors = new Set(visits.map((v) => v.visitorId)).size;
      const conversion = uniqueVisitors ? ((bookings.length / uniqueVisitors) * 100).toFixed(1) : '0.0';

      // Сводка по платежам: по пользователям и по квартирам
      // Сумма по пользователям
      const paymentsByUser = {};
      bookings.forEach((b) => {
        if (!paymentsByUser[b.userId]) paymentsByUser[b.userId] = { name: b.name, email: b.email, phone: b.phone, total: 0, count: 0 };
        paymentsByUser[b.userId].total += b.total;
        paymentsByUser[b.userId].count += 1;
      });
      // Сумма по квартирам
      const paymentsByApartment = {};
      bookings.forEach((b) => {
        const a = APARTMENTS.find((x) => x.id === b.apartmentId);
        const title = a ? a.title : b.apartmentId;
        if (!paymentsByApartment[b.apartmentId]) paymentsByApartment[b.apartmentId] = { title, total: 0, count: 0 };
        paymentsByApartment[b.apartmentId].total += b.total;
        paymentsByApartment[b.apartmentId].count += 1;
      });

      document.getElementById('owner').innerHTML = `
        <div class="grid cards-3">
          <div class="panel"><strong>${visits.length}</strong><p class="muted">Всего входов на сайт</p></div>
          <div class="panel"><strong>${uniqueVisitors}</strong><p class="muted">Уникальных посетителей</p></div>
          <div class="panel"><strong>${conversion}%</strong><p class="muted">Конверсия в бронирование</p></div>
        </div>

        <div class="panel" style="margin-top:12px;">
          <h2>Кто заходит на сайт</h2>
          <div style="overflow:auto; margin-top:8px;">
            <table class="table">
              <thead><tr><th>Время</th><th>Маршрут</th><th>Пользователь</th><th>Visitor ID</th></tr></thead>
              <tbody>
                ${visits.slice(0, 40).map((v) => `<tr><td>${new Date(v.at).toLocaleString('ru-RU')}</td><td>${v.route}</td><td>${v.userName}</td><td>${v.visitorId}</td></tr>`).join('') || '<tr><td colspan="4">Данных пока нет</td></tr>'}
              </tbody>
            </table>
          </div>
        </div>

        <div class="panel" style="margin-top:12px;">
          <h2>Какие квартиры смотрят</h2>
          <div style="overflow:auto; margin-top:8px;">
            <table class="table">
              <thead><tr><th>Время</th><th>Квартира</th><th>Пользователь</th><th>Visitor ID</th></tr></thead>
              <tbody>
                ${apartmentViews.slice(0, 40).map((v) => `<tr><td>${new Date(v.at).toLocaleString('ru-RU')}</td><td>${v.apartmentTitle}</td><td>${v.userName}</td><td>${v.visitorId}</td></tr>`).join('') || '<tr><td colspan="4">Данных пока нет</td></tr>'}
              </tbody>
            </table>
          </div>
        </div>

        <div class="panel" style="margin-top:12px;">
          <h2>Пользователи сайта</h2>
          <div style="overflow:auto; margin-top:8px;">
            <table class="table">
              <thead><tr><th>ID</th><th>Имя</th><th>Email</th><th>Телефон</th></tr></thead>
              <tbody>
                ${users.map((item) => `<tr><td>${item.id}</td><td>${item.name}</td><td>${item.email}</td><td>${item.phone || '-'}</td></tr>`).join('') || '<tr><td colspan="4">Пользователей пока нет</td></tr>'}
              </tbody>
            </table>
          </div>
        </div>

        <div class="panel" style="margin-top:12px;">
          <h2>Бронирования</h2>
          <div style="overflow:auto; margin-top:8px;">
            <table class="table">
              <thead><tr><th>ID</th><th>Квартира</th><th>Гость</th><th>Даты</th><th>Оплата</th><th>Сумма</th></tr></thead>
              <tbody>
                ${bookings.slice(0, 40).map((b) => {
                  const a = APARTMENTS.find((x) => x.id === b.apartmentId);
                  return `<tr><td>${b.id}</td><td>${a ? a.title : b.apartmentId}</td><td>${b.name}</td><td>${b.start} - ${b.end}</td><td>${b.paymentMethod}</td><td>${fmtMoney(b.total)}</td></tr>`;
                }).join('') || '<tr><td colspan="6">Бронирований пока нет</td></tr>'}
              </tbody>
            </table>
          </div>
          <div style="margin-top:10px; display:flex; gap:8px; flex-wrap:wrap;">
            <button class="btn btn-primary" onclick="exportCsv()">Экспорт CSV</button>
            <button class="btn btn-ghost" onclick="exportXls()">Экспорт Excel (.xls)</button>
          </div>
          <div class="panel" style="margin-top:18px;">
            <h3>Сводка по гостям</h3>
            <table class="table">
              <thead><tr><th>Гость</th><th>Email</th><th>Телефон</th><th>Сумма</th><th>Бронирований</th></tr></thead>
              <tbody>
                ${Object.values(paymentsByUser).map(u => `<tr><td>${u.name}</td><td>${u.email}</td><td>${u.phone || '-'}</td><td>${fmtMoney(u.total)}</td><td>${u.count}</td></tr>`).join('') || '<tr><td colspan="5">Нет данных</td></tr>'}
              </tbody>
            </table>
          </div>
          <div class="panel" style="margin-top:18px;">
            <h3>Сводка по квартирам</h3>
            <table class="table">
              <thead><tr><th>Квартира</th><th>Сумма</th><th>Бронирований</th></tr></thead>
              <tbody>
                ${Object.values(paymentsByApartment).map(a => `<tr><td>${a.title}</td><td>${fmtMoney(a.total)}</td><td>${a.count}</td></tr>`).join('') || '<tr><td colspan="3">Нет данных</td></tr>'}
              </tbody>
            </table>
          </div>
        </div>
      `;
    }

    function renderProfile() {
      const u = user();
      if (!u) {
        document.getElementById('profile').innerHTML = `<div class="panel"><h2>Профиль</h2><p class="muted">Чтобы открыть профиль, войдите или зарегистрируйтесь.</p><button class="btn btn-primary" onclick="openAuth('login')">Открыть вход</button></div>`;
        return;
      }

      const favoriteApartments = favoriteIdsForUser().map((id) => APARTMENTS.find((a) => a.id === id)).filter(Boolean);
      const myBookings = state.bookings.filter((b) => b.userId === u.id);

      document.getElementById('profile').innerHTML = `
        <div class="grid cards-3">
          <div class="panel"><h3>${u.name}</h3><p class="muted">Личный профиль</p></div>
          <div class="panel"><strong>${u.email}</strong><p class="muted">Email</p></div>
          <div class="panel"><strong>${u.phone || '-'}</strong><p class="muted">Телефон</p></div>
        </div>

        <div class="panel" style="margin-top:12px;">
          <h2>Избранные квартиры</h2>
          <div class="grid cards-3" style="margin-top:10px;">
            ${favoriteApartments.map((a) => `
              <div class="panel">
                <div class="shot" onclick="viewApartmentBySlug('${a.slug}')"><img src="${a.photos[0].thumb}" alt="${a.photos[0].alt}" loading="lazy"></div>
                <h3 style="margin-top:8px;">${a.title}</h3>
                <p class="muted">${a.district}</p>
                <div style="display:flex; gap:8px; flex-wrap:wrap; margin-top:8px;">
                  <button class="btn btn-ghost" onclick="toggleFavorite('${a.id}')">Убрать</button>
                  <button class="btn btn-primary" onclick="openBooking('${a.id}')">Бронировать</button>
                </div>
              </div>
            `).join('') || '<p class="muted">Вы пока не добавили квартиры в избранное.</p>'}
          </div>
        </div>

        <div class="panel" style="margin-top:12px;">
          <h2>Мои бронирования</h2>
          <p class="muted">Активных и завершенных бронирований: ${myBookings.length}</p>
          <div style="margin-top:10px; display:flex; gap:8px; flex-wrap:wrap;">
            <button class="btn btn-ghost" onclick="pushRoute('#/dashboard')">Открыть кабинет бронирований</button>
            <button class="btn btn-danger" onclick="logout()">Выйти из профиля</button>
          </div>
        </div>
      `;
    }

    function renderAbout() {
      document.getElementById('about').innerHTML = `
        <div class="panel">
          <h2>О сервисе</h2>
          <p class="muted">Home Comfort - сервис суточной аренды с акцентом на честные цены, визуальную прозрачность и контроль занятости.</p>
          <div class="grid cards-2" style="margin-top:10px;">
            <div class="panel">
              <h3>Что уже внедрено</h3>
              <ul style="padding-left:18px; margin-top:8px; line-height:1.6;">
                <li>Реальные фото + lightbox</li>
                <li>SEO и OpenGraph</li>
                <li>PWA (manifest + service worker)</li>
                <li>Промокоды и реферальная скидка</li>
                <li>Динамическое ценообразование</li>
                <li>Минимальный срок + черные даты</li>
                <li>Верификация SMS-кодом и документом</li>
              </ul>
            </div>
            <div class="panel">
              <h3>Контакты</h3>
              <p style="margin-top:8px;">Онлайн-чат на сайте и WhatsApp: <a href="https://wa.me/77001929260" target="_blank" rel="noreferrer">+7 700 192 9260</a></p>
            </div>
          </div>
        </div>
      `;
    }

    function renderNav() {
      document.getElementById('nav').innerHTML = navItems().map((n) => `<button data-target="${n.id}" onclick="pushRoute('#/${n.id}')">${n.title}</button>`).join('');
    }

    function openLightbox(apartmentId, idx) {
      lightbox = { apartmentId, index: idx };
      drawLightbox();
      document.getElementById('lightboxModal').classList.add('open');
    }

    function drawLightbox() {
      const apartment = APARTMENTS.find((a) => a.id === lightbox.apartmentId);
      if (!apartment) return;
      const photo = apartment.photos[lightbox.index];
      document.getElementById('lightboxTitle').textContent = apartment.title + ' - фото ' + (lightbox.index + 1) + '/' + apartment.photos.length;
      document.getElementById('lightboxImage').src = photo.src;
      document.getElementById('lightboxImage').alt = photo.alt;
    }

    function lightboxPrev() {
      const apartment = APARTMENTS.find((a) => a.id === lightbox.apartmentId);
      if (!apartment) return;
      lightbox.index = (lightbox.index - 1 + apartment.photos.length) % apartment.photos.length;
      drawLightbox();
    }

    function lightboxNext() {
      const apartment = APARTMENTS.find((a) => a.id === lightbox.apartmentId);
      if (!apartment) return;
      lightbox.index = (lightbox.index + 1) % apartment.photos.length;
      drawLightbox();
    }

    function openBooking(apartmentId) {
      const u = user();
      if (!u) {
        openAuth();
        return;
      }

      const apartment = APARTMENTS.find((a) => a.id === apartmentId);
      const start = new Date();
      start.setDate(start.getDate() + 1);
      const end = new Date(start);
      end.setDate(end.getDate() + apartment.minStay);

      const panel = document.createElement('div');
      panel.className = 'modal open';
      panel.id = 'bookingModal';
      panel.innerHTML = `
        <div class="modal-body">
          <div style="display:flex; justify-content:space-between; align-items:center; gap:8px;">
            <h3>Бронирование: ${apartment.title}</h3>
            <button class="btn btn-ghost" onclick="document.getElementById('bookingModal').remove()">Закрыть</button>
          </div>

          <div class="panel" style="margin-top:10px;">
            <strong>Как забронировать за 3 шага</strong>
            <p class="muted" style="margin-top:6px;">1) Выберите даты и заполните контакты. 2) При желании введите промокод или рефкод. 3) Пройдите верификацию и подтвердите бронь.</p>
          </div>

          <div class="grid cards-2" style="margin-top:10px;">
            <div class="panel">
              <div class="field"><label>Имя</label><input id="bkName" value="${u.name}"></div>
              <div class="field"><label>Телефон</label><input id="bkPhone" value="${u.phone}"></div>
              <div class="field"><label>Email</label><input id="bkEmail" value="${u.email}"></div>
              <div class="field"><label>Дата заезда</label><input id="bkStart" type="date" value="${ymd(start)}"></div>
              <div class="field"><label>Дата выезда</label><input id="bkEnd" type="date" value="${ymd(end)}"></div>
              <div class="field"><label>Промокод</label><input id="bkPromo" placeholder="PROMO10"></div>
              <div class="field"><label>Реферальный код</label><input id="bkRef" placeholder="REFCODE"></div>
              <div class="field"><label>Оплата</label><select id="bkPayment"><option value="card">Карта</option><option value="kaspi">Kaspi</option><option value="tinkoff">Tinkoff</option><option value="cash">Наличные при заезде</option></select></div>
            </div>

            <div class="panel">
              <h4>Верификация гостя</h4>
              <p class="muted">Для подтверждения брони нужен SMS-код и документ.</p>
              <div class="field" style="margin-top:8px;"><label>SMS код</label><div style="display:flex; gap:8px;"><button class="btn btn-ghost" onclick="sendOtp()">Отправить код</button><input id="otpInput" placeholder="4 цифры"></div></div>
              <div class="field"><label>Документ (фото/скан)</label><input id="docInput" type="file" accept="image/*,.pdf"></div>
              <button class="btn btn-primary" style="margin-top:8px;" onclick="verifyGuest()">Подтвердить верификацию</button>
              <p id="verifyStatus" class="muted" style="margin-top:8px;">Статус: не подтвержден</p>

              <h4 style="margin-top:12px;">Календарь занятости</h4>
              <div id="bookingCalendar"></div>
              <div id="bookingCalc" style="margin-top:10px;"></div>
              <p id="bookingReadiness" class="muted" style="margin-top:8px;"></p>
              <button id="bookingConfirmBtn" class="btn btn-primary" style="margin-top:10px;" onclick="confirmBooking('${apartment.id}')" disabled>Подтвердить бронь</button>
            </div>
          </div>
        </div>
      `;

      document.body.appendChild(panel);
      window.bookingContext = { apartmentId: apartment.id };
      window.bookingVerification = { otp: null, verified: false, documentName: null };
      renderBookingCalendar(apartment);
      recalcBooking(apartment);
      updateBookingReadiness(apartment);

      ['bkName','bkPhone','bkEmail','bkStart','bkEnd','bkPromo','bkRef','bkPayment'].forEach((id) => {
        document.getElementById(id).addEventListener('input', () => {
          renderBookingCalendar(apartment);
          recalcBooking(apartment);
          updateBookingReadiness(apartment);
        });
        document.getElementById(id).addEventListener('change', () => {
          renderBookingCalendar(apartment);
          recalcBooking(apartment);
          updateBookingReadiness(apartment);
        });
      });
    }

    function bookingValidation(apartment) {
      const name = document.getElementById('bkName')?.value.trim();
      const phone = document.getElementById('bkPhone')?.value.trim();
      const email = document.getElementById('bkEmail')?.value.trim();
      const start = document.getElementById('bkStart')?.value;
      const end = document.getElementById('bkEnd')?.value;

      if (!name || !phone || !email) return { ok: false, message: 'Заполните имя, телефон и email.' };
      if (!start || !end || end <= start) return { ok: false, message: 'Укажите корректный период заезда и выезда.' };

      const dates = rangeDates(start, end).map((d) => ymd(d));
      const nights = dates.length;
      if (nights < apartment.minStay) return { ok: false, message: `Минимальный срок: ${apartment.minStay} ночи.` };
      if (dates.some((d) => apartment.blacklist.includes(d))) return { ok: false, message: 'В выбранном периоде есть недоступные даты.' };
      if (dates.some((d) => isDateBusy(apartment.id, d))) return { ok: false, message: 'Часть выбранных дат уже занята.' };
      if (!window.bookingVerification || !window.bookingVerification.verified) return { ok: false, message: 'Пройдите верификацию (SMS + документ).' };
      return { ok: true, message: 'Все готово. Можно подтверждать бронь.' };
    }

    function updateBookingReadiness(apartment) {
      const node = document.getElementById('bookingReadiness');
      const btn = document.getElementById('bookingConfirmBtn');
      if (!node || !btn) return;
      const result = bookingValidation(apartment);
      node.textContent = result.message;
      node.style.color = result.ok ? 'var(--ok)' : 'var(--danger)';
      btn.disabled = !result.ok;
      btn.style.opacity = result.ok ? '1' : '0.6';
      btn.style.cursor = result.ok ? 'pointer' : 'not-allowed';
    }

    function renderBookingCalendar(apartment) {
      const start = document.getElementById('bkStart')?.value;
      const base = start ? new Date(start + 'T12:00:00') : new Date();
      const monthStart = new Date(base.getFullYear(), base.getMonth(), 1);
      const daysInMonth = new Date(base.getFullYear(), base.getMonth() + 1, 0).getDate();
      const firstWeekDay = (monthStart.getDay() + 6) % 7;
      let html = '<div class="calendar">';
      ['Пн','Вт','Ср','Чт','Пт','Сб','Вс'].forEach((d) => { html += `<div class="cal-head">${d}</div>`; });
      for (let i = 0; i < firstWeekDay; i++) html += '<div class="day past"></div>';

      for (let day = 1; day <= daysInMonth; day++) {
        const d = new Date(base.getFullYear(), base.getMonth(), day);
        const dateStr = ymd(d);
        const today = ymd(new Date());
        const isPast = dateStr < today;
        const inBlacklist = apartment.blacklist.includes(dateStr);
        const busy = isDateBusy(apartment.id, dateStr);

        let cls = 'day';
        if (isPast) cls += ' past';
        else if (inBlacklist) cls += ' blocked';
        else if (busy) cls += ' booked';

        html += `<div class="${cls}" title="${dateStr}">${day}</div>`;
      }
      html += '</div>';
      document.getElementById('bookingCalendar').innerHTML = html;
    }

    function recalcBooking(apartment) {
      const start = document.getElementById('bkStart')?.value;
      const end = document.getElementById('bkEnd')?.value;
      if (!start || !end || end <= start) {
        document.getElementById('bookingCalc').innerHTML = '<p class="muted">Выберите корректные даты.</p>';
        return;
      }

      const dates = rangeDates(start, end);
      const nights = dates.length;
      const nightly = dates.map((d) => dynamicNightPrice(apartment, ymd(d)));
      const subtotal = nightly.reduce((s, v) => s + v, 0);

      const promo = applyPromo(subtotal, document.getElementById('bkPromo').value, nights);
      const ref = applyReferral(subtotal, document.getElementById('bkRef').value);
      const total = Math.max(0, subtotal - promo.discount - ref.discount);
      const avg = nights ? total / nights : total;

      document.getElementById('bookingCalc').innerHTML = `
        <div class="panel">
          <div><strong>Ночей:</strong> ${nights}</div>
          <div><strong>Субтотал:</strong> ${fmtMoney(subtotal)}</div>
          <div><strong>${promo.label || 'Промокод'}:</strong> -${fmtMoney(promo.discount)}</div>
          <div><strong>${ref.label || 'Реферал'}:</strong> -${fmtMoney(ref.discount)}</div>
          <div><strong>Итого:</strong> ${fmtMoney(total)}</div>
          <div><strong>Средняя цена за ночь:</strong> ${fmtMoney(avg)}</div>
        </div>
      `;
    }

    function sendOtp() {
      const code = String(Math.floor(1000 + Math.random() * 9000));
      window.bookingVerification.otp = code;
      toast('SMS-код отправлен: ' + code + ' (демо)');
    }

    function verifyGuest() {
      const code = document.getElementById('otpInput').value.trim();
      const file = document.getElementById('docInput').files[0];
      if (!window.bookingVerification.otp) {
        toast('Сначала отправьте SMS-код');
        return;
      }
      if (code !== window.bookingVerification.otp) {
        toast('Неверный SMS-код');
        return;
      }
      if (!file) {
        toast('Загрузите документ');
        return;
      }
      window.bookingVerification.verified = true;
      window.bookingVerification.documentName = file.name;
      document.getElementById('verifyStatus').textContent = 'Статус: подтвержден (' + file.name + ')';
      const apartment = APARTMENTS.find((a) => a.id === window.bookingContext?.apartmentId);
      if (apartment) updateBookingReadiness(apartment);
      toast('Верификация пройдена');
    }

    function confirmBooking(apartmentId) {
      const apartment = APARTMENTS.find((a) => a.id === apartmentId);
      const start = document.getElementById('bkStart').value;
      const end = document.getElementById('bkEnd').value;
      const dates = rangeDates(start, end).map((d) => ymd(d));
      const nights = dates.length;
      const validation = bookingValidation(apartment);
      if (!validation.ok) {
        toast(validation.message);
        return;
      }

      const nightly = dates.map((d) => dynamicNightPrice(apartment, d));
      const subtotal = nightly.reduce((s, v) => s + v, 0);
      const promo = applyPromo(subtotal, document.getElementById('bkPromo').value, nights);
      const ref = applyReferral(subtotal, document.getElementById('bkRef').value);
      const total = Math.max(0, subtotal - promo.discount - ref.discount);

      const booking = {
        id: 'BK-' + Date.now(),
        apartmentId,
        userId: user().id,
        name: document.getElementById('bkName').value.trim(),
        phone: document.getElementById('bkPhone').value.trim(),
        email: document.getElementById('bkEmail').value.trim(),
        start,
        end,
        nights,
        dates,
        paymentMethod: document.getElementById('bkPayment').value,
        total,
        promo: document.getElementById('bkPromo').value.trim().toUpperCase(),
        referral: document.getElementById('bkRef').value.trim().toUpperCase(),
        verification: { sms: true, document: window.bookingVerification.documentName },
        createdAt: new Date().toISOString()
      };

      state.bookings.unshift(booking);
      state.analytics.leads += 1;
      if (!state.occupancy[apartmentId]) state.occupancy[apartmentId] = {};
      dates.forEach((d) => { state.occupancy[apartmentId][d] = booking.name; });
      saveState();

      document.getElementById('bookingModal').remove();
      renderDashboard();
      renderOwner();
      toast('Бронирование создано: ' + booking.id);
    }

    function exportCsv() {
      const headers = ['id','apartmentId','name','phone','email','start','end','nights','paymentMethod','total','promo','referral'];
      const rows = state.bookings.map((b) => headers.map((h) => (b[h] ?? '')).join(','));
      const csv = [headers.join(','), ...rows].join('\n');
      downloadFile(csv, 'report.csv', 'text/csv;charset=utf-8;');
      toast('CSV экспортирован');
    }

    function exportXls() {
      const html = `
        <table border="1">
          <tr><th>ID</th><th>Apartment</th><th>Name</th><th>Start</th><th>End</th><th>Nights</th><th>Payment</th><th>Total</th></tr>
          ${state.bookings.map((b) => `<tr><td>${b.id}</td><td>${b.apartmentId}</td><td>${b.name}</td><td>${b.start}</td><td>${b.end}</td><td>${b.nights}</td><td>${b.paymentMethod}</td><td>${b.total}</td></tr>`).join('')}
        </table>
      `;
      downloadFile(html, 'report.xls', 'application/vnd.ms-excel');
      toast('Excel экспортирован');
    }

    function downloadFile(content, filename, type) {
      const blob = new Blob([content], { type });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = filename;
      a.click();
      URL.revokeObjectURL(url);
    }

    function openAuth(mode = 'login', force = false) {
      window.authRequired = force;
      document.getElementById('authModal').classList.add('open');
      document.getElementById('authClose').style.display = force ? 'none' : 'inline-flex';
      renderAuthTab(mode);
    }

    function renderAuthTab(mode) {
      const container = document.getElementById('authContent');
      if (mode === 'login') {
        container.innerHTML = `
          <form onsubmit="login(event)">
            <div class="field"><label>Email</label><input id="loginEmail" placeholder="Email"></div>
            <div class="field"><label>${t('password')}</label><input id="loginPassword" type="password" placeholder="••••••••"></div>
            <button class="btn btn-primary" style="margin-top:10px; width:100%;" type="submit">${t('loginBtn')}</button>
          </form>
        `;
      } else {
        container.innerHTML = `
          <form onsubmit="registerUser(event)">
            <div class="field"><label>${t('name')}</label><input id="regName" required></div>
            <div class="field"><label>${t('phone')}</label><input id="regPhone" required></div>
            <div class="field"><label>Email</label><input id="regEmail" type="email" required></div>
            <div class="field"><label>${t('password')}</label><input id="regPassword" type="password" required></div>
            <button class="btn btn-primary" style="margin-top:10px; width:100%;" type="submit">${t('createAccount')}</button>
          </form>
        `;
      }
    }

    function login(event) {
      event.preventDefault();
      const email = document.getElementById('loginEmail').value.trim().toLowerCase();
      const pass = document.getElementById('loginPassword').value;
      const found = state.users.find((u) => u.email.toLowerCase() === email && u.password === pass);
      if (!found) {
        toast('Неверный логин или пароль');
        return;
      }
      state.sessionUserId = found.id;
      localStorage.setItem('staydaily-onboarded', '1');
      saveState();
      document.getElementById('authModal').classList.remove('open');
      renderAll();
      toast('Вход выполнен');
    }

    function registerUser(event) {
      event.preventDefault();
      const u = {
        id: 'u-' + Date.now(),
        role: 'guest',
        name: document.getElementById('regName').value.trim(),
        phone: document.getElementById('regPhone').value.trim(),
        email: document.getElementById('regEmail').value.trim(),
        password: document.getElementById('regPassword').value,
        referralCode: 'REF' + Math.floor(10000 + Math.random() * 90000)
      };
      state.users.push(u);
      state.sessionUserId = u.id;
      localStorage.setItem('staydaily-onboarded', '1');
      saveState();
      document.getElementById('authModal').classList.remove('open');
      renderAll();
      toast('Аккаунт создан');
    }

    function logout() {
      state.sessionUserId = null;
      saveState();
      renderAll();
      toast('Вы вышли');
    }

    function renderAuthButton() {
      const u = user();
      const btn = document.getElementById('authBtn');
      btn.textContent = t('profile');
      btn.onclick = () => {
        if (!u) {
          openAuth('login');
          return;
        }
        pushRoute('#/profile');
      };
    }

    function ensureFirstVisitRegistration() {
      const onboarded = localStorage.getItem('staydaily-onboarded') === '1';
      if (!onboarded && state.sessionUserId === 'guest') {
        state.sessionUserId = null;
        saveState();
      }
      // Не открываем принудительно - пусть юзер сам решит
    }

    function viewApartmentBySlug(slug) {
      const a = getApartmentBySlug(slug);
      if (!a) return;
      viewApartment(a);
    }

    function renderChat() {
      const log = document.getElementById('chatLog');
      log.innerHTML = state.chat.map((m) => `<div class="msg ${m.from === 'me' ? 'me' : 'bot'}">${m.text}</div>`).join('');
      log.scrollTop = log.scrollHeight;
    }

    function replyBot(text) {
      const t = text.toLowerCase();
      if (t.includes('цена')) return 'Цены динамические: зависят от сезона и дня недели. В карточке бронирования покажем полный расчет.';
      if (t.includes('документ') || t.includes('вериф')) return 'Для подтверждения брони нужен SMS-код и документ (фото паспорта/ID или PDF).';
      if (t.includes('скид')) return 'Поддерживаем промокоды и реферальные коды. Попробуйте PROMO10.';
      if (t.includes('человек') || t.includes('гост')) return 'В каталоге у каждой квартиры указана вместимость и минимальный срок проживания.';
      return 'Принял. Могу подобрать 2-3 варианта под ваш бюджет и даты. Напишите желаемые даты и бюджет.';
    }

    function bindChat() {
      const widget = document.getElementById('chatWidget');
      const open = () => widget.classList.add('open');
      const close = () => widget.classList.remove('open');
      document.getElementById('chatFab').onclick = open;
      document.getElementById('chatOpenBtn').onclick = open;
      document.getElementById('chatCloseBtn').onclick = close;

      document.getElementById('chatForm').onsubmit = (e) => {
        e.preventDefault();
        const input = document.getElementById('chatInput');
        const text = input.value.trim();
        if (!text) return;
        state.chat.push({ from: 'me', text });
        state.chat.push({ from: 'bot', text: replyBot(text) });
        input.value = '';
        saveState();
        renderChat();
      };

      renderChat();
    }

    function renderAll() {
      const langNode = document.getElementById('langSwitcher');
      if (langNode) langNode.value = currentLang;
      document.getElementById('brandTagline').textContent = t('brandTagline');
      document.getElementById('chatFab').textContent = t('chat');
      document.getElementById('chatTitle').textContent = t('onlineChat');
      document.getElementById('chatOpenBtn').textContent = t('onlineChat');
      document.getElementById('chatCloseBtn').textContent = t('close');
      document.getElementById('chatSendBtn').textContent = t('send');
      document.getElementById('chatInput').placeholder = t('questionPlaceholder');
      document.getElementById('lightboxClose').textContent = t('close');
      document.getElementById('lightboxPrev').textContent = t('prev');
      document.getElementById('lightboxNext').textContent = t('next');
      document.getElementById('authClose').textContent = t('close');
      document.getElementById('authModalTitle').textContent = t('loginTitle');
      document.getElementById('tabLogin').textContent = t('loginTab');
      document.getElementById('tabRegister').textContent = t('registerTab');

      renderNav();
      renderAuthButton();
      renderHome();
      renderCatalog();
      renderDashboard();
      renderProfile();
      renderOwner();
      renderAbout();
      resolveRoute();
    }

    // Lightbox bindings
    document.getElementById('lightboxClose').onclick = () => document.getElementById('lightboxModal').classList.remove('open');
    document.getElementById('lightboxPrev').onclick = lightboxPrev;
    document.getElementById('lightboxNext').onclick = lightboxNext;

    // Auth bindings
    document.getElementById('authClose').onclick = () => {
      if (window.authRequired) return;
      document.getElementById('authModal').classList.remove('open');
    };
    document.getElementById('tabLogin').onclick = () => renderAuthTab('login');
    document.getElementById('tabRegister').onclick = () => renderAuthTab('register');
    document.getElementById('langSwitcher').onchange = (e) => setLanguage(e.target.value);

    window.openLightbox = openLightbox;
    window.pushRoute = pushRoute;
    window.viewApartmentBySlug = viewApartmentBySlug;
    window.openBooking = openBooking;
    window.sendOtp = sendOtp;
    window.verifyGuest = verifyGuest;
    window.confirmBooking = confirmBooking;
    window.toggleFavorite = toggleFavorite;
    window.rebookOneClick = rebookOneClick;
    window.exportCsv = exportCsv;
    window.exportXls = exportXls;
    window.login = login;
    window.registerUser = registerUser;
    window.openAuth = openAuth;
    window.logout = logout;
    window.doSmartSearch = doSmartSearch;

    window.addEventListener('hashchange', () => {
      resolveRoute();
      trackVisit(location.hash || '#/home');
    });

    // PWA
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('./sw.js').catch(() => {});
    }

    bindChat();
    trackVisit(location.hash || '#/home');
    renderAll();
  </script>
</body>
  </html>