          <div style="margin-top:10px; display:flex; gap:8px; flex-wrap:wrap;">
            <a class="btn btn-ghost" href="https://wa.me/77001929260?text=${encodeURIComponent('Интересует квартира ' + a.title)}" target="_blank" rel="noreferrer">${t('whatsapp')}</a>
            <button class="btn btn-ghost" onclick="pushRoute('#/catalog')">${t('backToCatalog')}</button>
          </div>
