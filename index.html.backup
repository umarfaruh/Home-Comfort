    function loadLanguage() {
      const saved = localStorage.getItem(LANG_STORAGE);
      return SUPPORTED_LANGS.includes(saved) ? saved : 'ru';
    }

    let currentLang = loadLanguage();

    function t(key, vars = {}) {
      const table = I18N[currentLang] || I18N.ru;
      let value = table[key] || I18N.ru[key] || key;
      Object.keys(vars).forEach((name) => {
        value = value.replace(`{${name}}`, String(vars[name]));
      });
      return value;
    }

    function setLanguage(lang) {
      if (!SUPPORTED_LANGS.includes(lang)) return;
      currentLang = lang;
      localStorage.setItem(LANG_STORAGE, lang);
      renderAll();
    }

